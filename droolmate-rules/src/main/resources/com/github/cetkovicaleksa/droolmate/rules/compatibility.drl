package com.github.cetkovicaleksa.droolmate.rules;
import com.github.cetkovicaleksa.droolmate.model.Breed;
import com.github.cetkovicaleksa.droolmate.model.RoleRequirement;
import com.github.cetkovicaleksa.droolmate.model.PhysicalFit;
import com.github.cetkovicaleksa.droolmate.model.BehavioralFit;
import com.github.cetkovicaleksa.droolmate.model.CompatibilityScore;
import com.github.cetkovicaleksa.droolmate.model.Recommendation;
import java.util.List;

dialect "mvel"

/**
 * Layer 3: Compatibility & Final Recommendation
 * Combines physical and behavioral scores into final recommendations.
 * Depends on BehavioralFit facts from Layer 2.
 * Emits CompatibilityScore and Recommendation facts.
 *
 * @source: ADI Standards - minimum thresholds for service animals
 * @source: Hart (1985) - combined behavioral assessment
 */

rule "Compute combined compatibility score"
    agenda-group "compatibility"
    salience 15
    when
        $breed : Breed()
        $role : RoleRequirement()
        $physicalFit : PhysicalFit(breedName == $breed.name, roleId == $role.roleId)
        $behavioralFit : BehavioralFit(breedName == $breed.name, roleId == $role.roleId)
    then
        // Calculate physical score: 100 if both height and weight suitable, 50 if one, 0 if none
//        double physicalScore;
        if ($physicalFit.isHeightSuitable() && $physicalFit.isWeightSuitable()) {
            physicalScore = 100;
        } else if ($physicalFit.isHeightSuitable() || $physicalFit.isWeightSuitable()) {
            physicalScore = 50;
        } else {
            physicalScore = 0;
        }

        // Calculate behavioral score: weighted average of Hart factors
        behavioralScore = ($behavioralFit.getTrainabilityFit() * 0.5) +
                               ($behavioralFit.getAggressionFit() * 0.3) +
                               ($behavioralFit.getReactivityFit() * 0.2);
        behavioralScore = Math.min(100, Math.max(0, behavioralScore));

        // Combined score: Physical 30% + Behavioral 70%
        combinedScore = (physicalScore * 0.3) + (behavioralScore * 0.7);
        combinedScore = Math.min(100, Math.max(0, combinedScore));

        // Check ADI thresholds
        boolean physicalOk = physicalScore >= 50;
        boolean behavioralOk = behavioralScore >= 75;
        boolean combinedOk = combinedScore >= 75;

        Recommendation.Level level = Recommendation.Level.fromScore(combinedScore);

        String explanation = 
            "Physical: " + String.format("%.1f%%", physicalScore) + 
            " (height=" + ($physicalFit.isHeightSuitable() ? "✓" : "✗") + 
            ", weight=" + ($physicalFit.isWeightSuitable() ? "✓" : "✗") + ") | " +
            "Behavioral: " + String.format("%.1f%%", behavioralScore) + 
            " (reactivity=" + String.format("%.0f%%", $behavioralFit.getReactivityFit()) +
            ", aggression=" + String.format("%.0f%%", $behavioralFit.getAggressionFit()) +
            ", trainability=" + String.format("%.0f%%", $behavioralFit.getTrainabilityFit()) + ") | " +
            "Combined: " + String.format("%.1f%%", combinedScore) + " (" + level.getDisplayName() + ")";

        CompatibilityScore compatScore = new CompatibilityScore(
            $breed.getName(),
            $role.getRoleId(),
            $physicalFit,
            $behavioralFit,
            combinedScore,
            physicalOk,
            behavioralOk,
            combinedOk,
            level,
            explanation
        );

        insert(compatScore);
end

rule "Emit recommendation from compatibility score"
    agenda-group "compatibility"
    salience 10
    when
        $breed : Breed()
        $role : RoleRequirement()
        $compatScore : CompatibilityScore(breedName == $breed.name, roleId == $role.roleId)
        $physicalFit : PhysicalFit(breedName == $breed.name, roleId == $role.roleId)
        $behavioralFit : BehavioralFit(breedName == $breed.name, roleId == $role.roleId)
    then
        boolean recommended = $compatScore.isPhysicalOk() && $compatScore.isBehavioralOk() && $compatScore.isCombinedOk();

        Recommendation recommendation = new Recommendation(
            $breed.getName(),
            $role.getRoleId(),
            $role.getRoleName(),
            $physicalFit,
            $behavioralFit,
            $compatScore.getCombinedScore(),
            recommended,
            $compatScore.getLevel(),
            $compatScore.getExplanation()
        );

        insert(recommendation);
end

rule "Rank breed recommendations for role"
    agenda-group "compatibility"
    salience 5
    when
        $role : RoleRequirement()
        $recommendations : List(size > 0) from accumulate(
            $rec : Recommendation(roleId == $role.roleId),
            init(List list = new java.util.ArrayList()),
            action(list.add($rec)),
            result(list)
        )
    then
        java.util.stream.Stream stream = $recommendations.stream();
        java.util.List sorted = stream.sorted((r1, r2) -> {
            Recommendation rec1 = (Recommendation) r1;
            Recommendation rec2 = (Recommendation) r2;
            return Double.compare(rec2.getCombinedScore(), rec1.getCombinedScore());
        }).collect(java.util.stream.Collectors.toList());

        System.out.println("\n=== Recommendations for " + $role.getRoleName() + " ===");
        for (int i = 0; i < sorted.size(); i++) {
            Recommendation rec = (Recommendation) sorted.get(i);
            String status = rec.isRecommended() ? "✓" : "✗";
            System.out.println((i+1) + ". " + status + " " + rec.getBreedName() + 
                              " - " + String.format("%.1f%%", rec.getCombinedScore()) + 
                              " (" + rec.getLevelDisplayName() + ")");
        }
        System.out.println("===\n");
end
